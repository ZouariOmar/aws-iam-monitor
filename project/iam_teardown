#!/usr/bin/env bash
# =========================================
# .FILE
#   iam_teardown
#
# .SYNOPSIS
#   AWS IAM environment cleanup automation script
#
# .DESCRIPTION
#   Removes IAM users, roles, and policies created
#   by the IAM setup automation workflow.
#
#   This script is part of IAMSentinel, a real-time AWS IAM
#   auditing and monitoring project. It cleans up IAM resources
#   used to generate CloudTrail events for security monitoring.
#
# .INPUTS
#   users.csv
#   policies/*.json
#   lib/*
#
# .OUTPUTS
#   Deletes AWS IAM users, roles, and policies.
#   Outputs execution logs to stdout.
#
# .NOTES
#   Project       : aws-iam-monitor
#   Version       : 1.0
#   Author        : @ZouariOmar (zouariomar20@gmail.com)
#   Created       : 14/07/2026
#   Change Log    : 1.0 Initial release
#
# .EXAMPLE
#   ./iam_teardown
#
# .REQUIREMENTS
#   - AWS CLI v2
#   - Python
#   - Configured AWS credentials
#   - IAM permissions:
#       iam:GetUser
#       iam:DeleteUser
#       iam:DetachUserPolicy
#       iam:GetRole
#       iam:DeleteRole
#       iam:DetachRolePolicy
#       iam:GetPolicy
#       iam:DeletePolicy
#       iam:DeletePolicyVersion
#
# shellcheck disable=SC1090
# =========================================

set -e

# ========================
# === Custom conf part ===
# ========================

USERS_CSV_FILE="users.csv"
LIB_DIR="lib"
AWS_ACCOUNT_ID="${1:-}"
VERBOSE=${2:-false}

# =========================
# === !Custom conf part ===
# =========================

# Load `common`
if [[ -s "${LIB_DIR}/common" ]]; then
  # shellcheck disable=SC1091
  . "${LIB_DIR}/common"
else
  echo "[ERROR] Missing Script: '${LIB_DIR}/common'"
  exit 1
fi

# ========================
# === AWS-IAM Teardown ===
# ========================

delete_user() {
  local USERNAME=$1
  local POLICY_NAME=$2
  local POLICY_ARN="arn:aws:iam::${AWS_ACCOUNT_ID}:policy/${POLICY_NAME}"

  if ! aws iam get-user --user-name "$USERNAME" >/dev/null 2>&1; then
    msg INFO "User '$USERNAME' does not exist."
    return
  fi

  aws iam detach-user-policy \
    --user-name "$USERNAME" \
    --policy-arn "$POLICY_ARN" 2>/dev/null || true

  aws iam delete-user \
    --user-name "$USERNAME"

  if [[ "$VERBOSE" == true ]]; then
    msg SUCCESS "Deleted user: $USERNAME"
  fi
}

delete_role() {
  local ROLE_NAME=$1

  if ! aws iam get-role \
    --role-name "$ROLE_NAME" >/dev/null 2>&1; then
    msg INFO "Role '$ROLE_NAME' does not exist."
    return
  fi

  # Remove attached managed policies
  while read -r POLICY_ARN; do
    [[ -z "$POLICY_ARN" ]] && continue

    aws iam detach-role-policy \
      --role-name "$ROLE_NAME" \
      --policy-arn "$POLICY_ARN"

    if [[ "$VERBOSE" == true ]]; then
      msg INFO "Detached role policy: $POLICY_ARN"
    fi

  done < <(
    aws iam list-attached-role-policies \
      --role-name "$ROLE_NAME" \
      --query 'AttachedPolicies[].PolicyArn' \
      --output text | tr '\t' '\n'
  )

  # Remove inline policies
  while read -r POLICY_NAME; do
    [[ -z "$POLICY_NAME" ]] && continue

    aws iam delete-role-policy \
      --role-name "$ROLE_NAME" \
      --policy-name "$POLICY_NAME"

    if [[ "$VERBOSE" == true ]]; then
      msg INFO "Deleted inline policy: $POLICY_NAME"
    fi

  done < <(
    aws iam list-role-policies \
      --role-name "$ROLE_NAME" \
      --query 'PolicyNames[]' \
      --output text | tr '\t' '\n'
  )

  # Remove instance profiles
  while read -r PROFILE; do
    [[ -z "$PROFILE" ]] && continue

    aws iam remove-role-from-instance-profile \
      --instance-profile-name "$PROFILE" \
      --role-name "$ROLE_NAME"

    if [[ "$VERBOSE" == true ]]; then
      msg INFO "Removed role from instance profile: $PROFILE"
    fi

  done < <(
    aws iam list-instance-profiles-for-role \
      --role-name "$ROLE_NAME" \
      --query 'InstanceProfiles[].InstanceProfileName' \
      --output text | tr '\t' '\n'
  )

  aws iam delete-role \
    --role-name "$ROLE_NAME"

  if [[ "$VERBOSE" == true ]]; then
    msg SUCCESS "Deleted role: $ROLE_NAME"
  fi
}

delete_policy() {
  local POLICY_NAME=$1
  local POLICY_ARN="arn:aws:iam::${AWS_ACCOUNT_ID}:policy/${POLICY_NAME}"

  if ! aws iam get-policy \
    --policy-arn "$POLICY_ARN" >/dev/null 2>&1; then
    msg INFO "Policy '$POLICY_NAME' does not exist."
    return
  fi

  if [[ "$VERBOSE" == true ]]; then
    msg INFO "Removing attachments for policy: $POLICY_NAME"
  fi

  # Detach from users
  for USER in $(aws iam list-entities-for-policy \
    --policy-arn "$POLICY_ARN" \
    --query 'PolicyUsers[].UserName' \
    --output text 2>/dev/null || true); do

    aws iam detach-user-policy \
      --user-name "$USER" \
      --policy-arn "$POLICY_ARN"

    if [[ "$VERBOSE" == true ]]; then
      msg INFO "Detached policy from user: $USER"
    fi
  done

  # Detach from roles
  for ROLE in $(aws iam list-entities-for-policy \
    --policy-arn "$POLICY_ARN" \
    --query 'PolicyRoles[].RoleName' \
    --output text 2>/dev/null || true); do

    aws iam detach-role-policy \
      --role-name "$ROLE" \
      --policy-arn "$POLICY_ARN"

    if [[ "$VERBOSE" == true ]]; then
      msg INFO "Detached policy from role: $ROLE"
    fi
  done

  # Detach from groups
  for GROUP in $(aws iam list-entities-for-policy \
    --policy-arn "$POLICY_ARN" \
    --query 'PolicyGroups[].GroupName' \
    --output text 2>/dev/null || true); do

    aws iam detach-group-policy \
      --group-name "$GROUP" \
      --policy-arn "$POLICY_ARN"

    if [[ "$VERBOSE" == true ]]; then
      msg INFO "Detached policy from group: $GROUP"
    fi
  done

  # Remove old policy versions
  while read -r VERSION; do
    [[ -z "$VERSION" ]] && continue

    aws iam delete-policy-version \
      --policy-arn "$POLICY_ARN" \
      --version-id "$VERSION"

    if [[ "$VERBOSE" == true ]]; then
      msg INFO "Deleted policy version: $VERSION"
    fi

  done < <(
    aws iam list-policy-versions \
      --policy-arn "$POLICY_ARN" \
      --query 'Versions[?!IsDefaultVersion].VersionId' \
      --output text 2>/dev/null | tr '\t' '\n'
  )

  # Delete policy
  aws iam delete-policy \
    --policy-arn "$POLICY_ARN"

  if [[ "$VERBOSE" == true ]]; then
    msg SUCCESS "Deleted policy: $POLICY_NAME"
  fi
}

# ==========================
# === !AWS-IAM Teardown ===
# ==========================

main() {
  load_script "${LIB_DIR}/logger"
  load_script "${LIB_DIR}/requirements"
  msg ".\n.\n."

  require_variable "AWS_ACCOUNT_ID"
  msg INFO "Starting IAM cleanup..."
  msg "."

  tail -n +2 "$USERS_CSV_FILE" | while IFS=', ' read -r USER ROLE POLICY; do
    msg INFO "USER: $USER | ROLE: $ROLE | POLICY: $POLICY"
    msg "."

    delete_user "$USER" "$POLICY"
    delete_role "$ROLE" "$POLICY"
    delete_policy "$POLICY"
    msg "----------------------------------"
  done

  msg SUCCESS "IAM teardown complete!"
  msg INFO "IAM Console: https://console.aws.amazon.com/iam/home"
  msg INFO "Users      : https://console.aws.amazon.com/iam/home#/users"
  msg INFO "Roles      : https://console.aws.amazon.com/iam/home#/roles"
  msg INFO "Policies   : https://console.aws.amazon.com/iam/home#/policies"
}

# Run all
main
