#!/usr/bin/env bash
# =========================================
# .FILE
#   iamctl
#
# .SYNOPSIS
#   AWS IAM lifecycle orchestration command
#
# .DESCRIPTION
#   Provides a unified command-line interface for
#   managing the AWS IAM environment lifecycle.
#
#   The script orchestrates IAM resource management
#   operations by executing dedicated management
#   modules:
#
#       - user_management
#       - group_management
#       - role_management
#       - policy_management
#
#   Supported lifecycle operations:
#
#       --up
#           Creates and configures IAM users, groups,
#           roles, and policies.
#
#       --down
#           Removes IAM users, groups, roles,
#           and policies created by the setup workflow.
#
#   Supports verbose execution mode for detailed
#   lifecycle logs, AWS account information, and
#   debugging output.
#
#   This script is part of aws-iam-monitor,
#   a real-time AWS IAM auditing and monitoring project.
#
# .INPUTS
#   Commands:
#
#   --up
#       Executes IAM setup workflow.
#
#       Creates:
#           - IAM policies
#           - IAM groups
#           - IAM roles (optional)
#           - IAM users
#
#   --down
#       Executes IAM teardown workflow.
#
#       Removes:
#           - IAM users
#           - IAM roles
#           - IAM groups
#           - IAM policies
#
#   -v, --verbose
#       Enables verbose lifecycle execution logs.
#
#   -h, --help
#       Displays usage information.
#
# .OUTPUTS
#   Executes IAM lifecycle operations through
#   dedicated management scripts.
#
#   Outputs execution status and logs to stdout.
#
# .NOTES
#   Project       : aws-iam-monitor
#   Version       : 1.0
#   Author        : @ZouariOmar (zouariomar20@gmail.com)
#   Created       : 14/07/2026
#   Change Log    : 1.0 Initial release
#
# .EXAMPLE
#
#   Create IAM environment:
#
#       ./iamctl --up
#
#
#   Remove IAM environment:
#
#       ./iamctl --down
#
#
#   Create IAM environment with verbose logs:
#
#       ./iamctl --up --verbose
#
#
#   Remove IAM environment with verbose logs:
#
#       ./iamctl --down -v
#
#
# .REQUIREMENTS
#   - AWS CLI v2
#   - Configured AWS credentials
#
#   Required IAM permissions depend on selected action:
#
#       --up:
#           iam:CreateUser
#           iam:CreateGroup
#           iam:CreateRole
#           iam:CreatePolicy
#           iam:CreatePolicyVersion
#           iam:Attach*
#           iam:AddUserToGroup
#
#       --down:
#           iam:DeleteUser
#           iam:DeleteGroup
#           iam:DeleteRole
#           iam:DeletePolicy
#           iam:DeletePolicyVersion
#           iam:Detach*
#           iam:RemoveUserFromGroup
#
# shellcheck disable=SC1090
# =========================================
set -Eeuo pipefail

# Directories
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
LIB_DIR="${LIB_DIR:-${SCRIPT_DIR}/lib}"
RES_DIR="${RES_DIR:-${SCRIPT_DIR}/res}"
SRC_DIR="${SRC_DIR:-${SCRIPT_DIR}/src}"

# Scripts
POLICY_MANAGEMENT_SCRIPT="${POLICY_MANAGEMENT_SCRIPT:-${SRC_DIR}/policy_management}"
GROUP_MANAGEMENT_SCRIPT="${GROUP_MANAGEMENT_SCRIPT:-${SRC_DIR}/group_management}"
ROLE_MANAGEMENT_SCRIPT="${ROLE_MANAGEMENT_SCRIPT:-${SRC_DIR}/role_management}"
USER_MANAGEMENT_SCRIPT="${USER_MANAGEMENT_SCRIPT:-${SRC_DIR}/user_management}"

# Resources
USERS_CSV_FILE="${USERS_CSV_FILE:-${RES_DIR}/users.csv}"
GROUPS_CSV_FILE="${GROUPS_CSV_FILE:-${RES_DIR}/groups.csv}"
ROLES_CSV_FILE="${ROLES_CSV_FILE:-${RES_DIR}/roles.csv}"

# Global vars
VERBOSE=${VERBOSE:-false}
AWS_ACCOUNT_ID=${AWS_ACCOUNT_ID:-}
ENABLE_ROLES=${ENABLE_ROLES:-false}

# Load scripts
if [[ -s "${LIB_DIR}/common" ]]; then
  # shellcheck disable=SC1091
  . "${LIB_DIR}/common"
else
  echo "[ERROR] Missing Script: '${LIB_DIR}/common'"
  exit 1
fi
load_script "${LIB_DIR}/logger"
load_script "${LIB_DIR}/requirements"

# Check requirements
check_requirements aws jq sed

check_aws_auth() {
  msg INFO "Checking AWS credentials..."

  if aws sts get-caller-identity >/dev/null 2>&1; then

    AWS_ACCOUNT_ID=$(aws sts get-caller-identity \
      --query Account \
      --output text)

    USER=$(aws sts get-caller-identity \
      --query Arn \
      --output text)

    if [[ "$VERBOSE" == true ]]; then
      msg SUCCESS "AWS authentication successful"
      msg INFO "Account: $AWS_ACCOUNT_ID"
      msg INFO "Identity: $USER"
    fi

  else
    msg ERROR "AWS credentials are not configured"
    msg INFO "Run: aws configure"
    exit 1
  fi
}

usage() {
  cat <<EOF
$(msg "USAGE:")

  $(basename "$0") <command> [options]


$(msg "DESCRIPTION:")

  $(basename "$0") orchestrates AWS IAM lifecycle operations
  through dedicated management scripts.

  Managed resources:

      - IAM Users
      - IAM Groups
      - IAM Roles (optional)
      - IAM Policies


$(msg "COMMANDS:")

  --up
      Create or update IAM environment.

      Executes:
        - policy_management
        - group_management
        - role_management (optional)
        - user_management

  --down
      Remove IAM environment.

      Executes:
        - user_management
        - role_management (optional)
        - group_management
        - policy_management


$(msg "OPTIONS:")

  -r, --role
      Enable IAM role management.

      When enabled:
        - Creates IAM roles during setup.
        - Deletes IAM roles during teardown.

  -v, --verbose
      Enable verbose lifecycle logs.

  -h, --help
      Show this help message.


$(msg "EXAMPLES:")

  Setup IAM environment:

      $(basename "$0") --up

  Teardown IAM environment:

      $(basename "$0") --down

  Setup IAM environment with roles:

      $(basename "$0") --up --role

  Teardown IAM environment with roles:

      $(basename "$0") --down --role

  Enable verbose output:

      $(basename "$0") --up --verbose

      $(basename "$0") --down -v

  Enable roles and verbose output:

      $(basename "$0") --up --role --verbose
EOF
  exit 1
}

setup() {
  local ACTION=$1

  msg INFO "$([ "$ACTION" == "--up" ] &&
    echo "Starting IAM Setup..." ||
    echo "Starting IAM cleanup...")"

  msg ".\n.\n."

  ARGS=()

  if [[ "$VERBOSE" == true ]]; then
    ARGS+=(--verbose)
  fi

  # Policies and groups
  while IFS=', ' read -r GROUP POLICY; do
    if [[ "$VERBOSE" == true ]]; then
      msg INFO "GROUP: $GROUP | POLICY: $POLICY"
    fi

    # Create/Delete Policy
    run_script \
      "$POLICY_MANAGEMENT_SCRIPT" \
      "$ACTION" \
      --aws-account-id "$AWS_ACCOUNT_ID" \
      --policy "$POLICY" \
      "${ARGS[@]}"

    # Create/Delete Group
    run_script \
      "$GROUP_MANAGEMENT_SCRIPT" \
      "$ACTION" \
      --aws-account-id "$AWS_ACCOUNT_ID" \
      --group "$GROUP" \
      --policy "$POLICY" \
      "${ARGS[@]}"

    msg "."
  done < <(tail -n +2 "$GROUPS_CSV_FILE")

  # Users
  while IFS=', ' read -r USER GROUP; do
    if [[ "$VERBOSE" == true ]]; then
      msg INFO "USER: $USER | GROUP: $GROUP"
    fi

    # Create/Delete User
    run_script \
      "$USER_MANAGEMENT_SCRIPT" \
      "$ACTION" \
      --user "$USER" \
      --group "$GROUP" \
      "${ARGS[@]}"

    msg "."

  done < <(tail -n +2 "$USERS_CSV_FILE")

  # Roles
  if [[ "$ENABLE_ROLES" == true ]]; then
    while IFS=', ' read -r ROLE POLICY; do
      if [[ "$VERBOSE" == true ]]; then
        msg INFO "ROLE: $ROLE | POLICY: $POLICY"
      fi

      # Reset role policy argument foreach role
      ARGS=()

      if [[ "$VERBOSE" == true ]]; then
        ARGS+=(--verbose)
      fi

      if [[ "$ACTION" == "--up" ]]; then
        ARGS+=(--policy "$POLICY")
      fi

      # Create/Delete Role
      run_script \
        "$ROLE_MANAGEMENT_SCRIPT" \
        "$ACTION" \
        --aws-account-id "$AWS_ACCOUNT_ID" \
        --role "$ROLE" \
        "${ARGS[@]}"
      msg "."
    done < <(tail -n +2 "$ROLES_CSV_FILE")
  fi

  msg SUCCESS "$([ "$ACTION" == "--up" ] &&
    echo "IAM Setup Complete!" ||
    echo "IAM teardown complete!")"

  msg INFO "IAM Console...https://console.aws.amazon.com/iam/home"
  msg INFO "Users.........https://console.aws.amazon.com/iam/home#/users"
  msg INFO "Groups........https://console.aws.amazon.com/iam/home#/groups"
  msg INFO "Roles.........https://console.aws.amazon.com/iam/home#/roles"
  msg INFO "Policies......https://console.aws.amazon.com/iam/home#/policies"
}

main() {
  local ACTION="--up"

  while [[ $# -gt 0 ]]; do
    case "$1" in
    --up | --down)
      ACTION="$1"
      ;;

    -v | --verbose)
      VERBOSE=true
      ;;

    -r | --role)
      ENABLE_ROLES=true
      ;;

    -h | --help)
      usage
      ;;

    *)
      msg ERROR "Unknown option: $1"
      usage
      ;;
    esac
    shift
  done

  check_aws_auth
  setup "$ACTION"
}

main "$@"
